   "id": "d41da047-77eb-4a36-b24f-beed634d55a3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total batches: 8\n",
      "Batch 1/8: 375 features — running total: 375\n",
      "Batch 2/8: 163 features — running total: 538\n",
      "Batch 3/8: 335 features — running total: 873\n",
      "Batch 4/8: 247 features — running total: 1120\n",
      "Batch 5/8: 221 features — running total: 1341\n",
      "Batch 6/8: 170 features — running total: 1511\n",
      "Batch 7/8: 193 features — running total: 1704\n",
      "Batch 8/8: 207 features — running total: 1911\n",
      "\n",
      "Total features retrieved: 1911\n"
     ]
    }
   ],
   "source": [
    "# since there are 400 roads, we will work in batches to not overload the API\n",
    "\n",
    "all_features = []\n",
    "batch_size = 50\n",
    "\n",
    "WFS_URL = \"https://gagnaveita.vegagerdin.is/geoserver/gis/ows\"\n",
    "\n",
    "# splitting into batches of 50\n",
    "batches = [road_numbers[i:i+batch_size] for i in range(0, len(road_numbers), batch_size)]\n",
    "print(f\"Total batches: {len(batches)}\")\n",
    "\n",
    "for i, batch in enumerate(batches):\n",
    "    road_filter = f\"VEGNR IN ({','.join(batch)})\"\n",
    "    \n",
    "    # pass relevant parameters to API\n",
    "    params_batch = {\n",
    "        \"service\":      \"WFS\",\n",
    "        \"version\":      \"1.0.0\",\n",
    "        \"request\":      \"GetFeature\",\n",
    "        \"typeName\":     \"gis:vegakerfi_ist120_2024_1\",\n",
    "        \"srsName\":      \"EPSG:4326\",\n",
    "        \"outputFormat\": \"application/json\",\n",
    "        \"cql_filter\":   road_filter\n",
    "    }\n",
    "\n",
    "    # perform the request\n",
    "    r = requests.get(WFS_URL, params=params_batch, timeout=120)\n",
    "\n",
    "    # checking for errors and reporting accordingly\n",
    "    if r.status_code == 200:\n",
    "        data = r.json()\n",
    "        all_features.extend(data['features'])\n",
    "        print(f\"Batch {i+1}/{len(batches)}: {len(data['features'])} features — running total: {len(all_features)}\")\n",
    "    else:\n",
    "        print(f\"Batch {i+1} failed: status {r.status_code}\")\n",
    "        print(r.text[:200])\n",
    "\n",
    "    # ensuring the server is not overloaded\n",
    "    time.sleep(1)  \n",
    "\n",
    "print(f\"\\nTotal features retrieved: {len(all_features)}\")"
   ]
  },
