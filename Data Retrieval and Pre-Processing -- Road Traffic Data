   "source": [
    "# for those road where there are several kaflanr representing sub-segments, we need to take a weighted average (based on the length of the \n",
    "# segment) to be able to later match them with geometries retrieved from Vegagerðin's GeoServer API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "8e4865a2-a757-45b0-827c-0b5d60046480",
   "metadata": {},
   "outputs": [],
   "source": [
    "# first, we create a function to calculate the weighted average of the sub-segments\n",
    "\n",
    "def wavg(group, val_col, weight_col):\n",
    "    return np.average(group[val_col], weights=group[weight_col])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 121,
   "id": "b4570832-26bc-4588-9d8c-5a10d51aed3e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# next, we need to group the dataframe by kaflanr and vegnr (road number) to uniquely identify each segment\n",
    "# then we can apply our function to them, by renaming sub-segments to group them, summing up the length of the sub-segments, and\n",
    "# creating length-weighted averages for the segments using the function we created above\n",
    "\n",
    "kaflanr = road_df.groupby([\"Vegnr\", \"Kaflanr\"]).apply(\n",
    "    lambda g: pd.Series({\n",
    "        \"Vegheiti\":     g[\"Vegheiti\"].iloc[0], # renaming road to the first name\n",
    "        # next we ensure we have a segment that has a name\n",
    "        \"Start_name\":   g[\"Start_name\"].dropna().iloc[0] if g[\"Start_name\"].notna().any() else None,\n",
    "        \"End_name\":     g[\"End_name\"].dropna().iloc[0]   if g[\"End_name\"].notna().any()   else None,\n",
    "        \"Lengd\":        g[\"Lengd\"].sum(), # calculating the length\n",
    "        \"rADU\":         wavg(g, \"rADU\", \"Lengd\"), # all year data\n",
    "        \"rSDU\":         wavg(g, \"rSDU\", \"Lengd\"), # summer data\n",
    "        \"summer_ratio\": wavg(g, \"summer_ratio\", \"Lengd\"), # summer ratio we created above\n",
    "        \"rVDU\":         wavg(g, \"rVDU\", \"Lengd\")\n",
    "    })\n",
    ", include_groups=False).reset_index()"
   ]
